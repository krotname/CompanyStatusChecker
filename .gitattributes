# Auto detect text files and perform LF normalization
* text=auto
.gitattributes text eol=lf
.editorconfig text eol=lf
.dockerignore text eol=lf
*.java text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
mvnw text eol=lf
mvnw.cmd text eol=crlf
